# ============================================================
# LinkMan VPN - Client Configuration Template
# ============================================================
# Copy this file to ~/.linkman/client_config.toml or use
# the GUI to configure and save settings.
#
# Server deployment: see linkman.server.toml
# GUI mode:           linkman-client (or: linkman-client --gui)
# CLI mode:           linkman-client -c linkman.toml
# ============================================================

[client]
local_host = "127.0.0.1"
local_port = 1080
# Server IP/hostname from the deployed server node
server_host = "your-server-ip"
server_port = 8388
connection_timeout = 30
buffer_size = 65536

[crypto]
cipher = "chacha20-poly1305"
# Paste the key generated on the server (linkman-server --generate-key)
key = ""
identity = ""

[traffic]
enabled = true
limit_mb = 0  # 0 = unlimited
warning_threshold_mb = 1000
reset_day = 1

[device]
max_devices = 5
session_timeout = 3600
allowed_devices = []

[log]
level = "INFO"
file = "logs/linkman.log"
max_size_mb = 10
backup_count = 5
format = "{time:YYYY-MM-DD HH:mm:ss} | {level: <8} | {message}"

[tls]
# Enable TLS + WebSocket for traffic obfuscation
# (server must also have tls.enabled = true)
enabled = false
cert_file = ""
key_file = ""
domain = ""
websocket_path = "/linkman"
websocket_enabled = false

protocol = "shadowsocks2022"
