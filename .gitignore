# LinkMan VPN .gitignore file

# Virtual environments
venv/
env/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs/
*.log

# Configuration files (contains sensitive information)
linkman.toml
linkman-*.toml
test-*.toml
~/.linkman/
*.json
!linkman.toml.example

# Certificates and keys
*.pem
*.key
*.crt

# Compiled files
__pycache__/
*.pyc

# Build artifacts
build/
dist/
*.egg-info/

# Docker
.dockerignore

# OS specific files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# Test files
.coverage
coverage.xml
pytest_cache/

# CI/CD
.github/workflows/*.yml

# Deployment scripts (may contain sensitive information)
restore_proxy.sh

# Temporary files
/tmp
/temp

# Database files
data/*.db
data/*.db-wal
data/*.db-shm
